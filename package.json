{
  "name": "app",
  "private": true,
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.2.1"
  },
  "scripts": {
    "build": "esbuild app/javascript/application.jsx --bundle --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets --loader:.jsx=jsx --jsx=automatic",
    "build:css": "npx @tailwindcss/cli -i ./app/assets/stylesheets/application.tailwind.css -o ./app/assets/builds/application.css --minify"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@rails/actioncable": "^8.1.200",
    "apollo-upload-client": "^19.0.0",
    "graphql": "^16.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-router-dom": "^7.13.1",
    "rxjs": "^7.8.2"
  }
}
